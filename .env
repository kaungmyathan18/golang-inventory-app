# Copy to .env and adjust. Values here override compiled defaults; real environment variables override .env.

APP_ENV=development

# HTTP: listen port is defined in config.DefaultConfig (default 8080). Wire viper + envInt("SERVER_PORT", 8080) there if you want PORT from the environment.

# Logging
LOG_LEVEL=info
LOG_FORMAT=console

# OpenTelemetry (matches observability preset that enables OTLP)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_INSECURE=true

# SQLite — only DB_DSN is used by the driver; other DB_* fields in config are ignored.
# Ensure the directory for the DB file exists (e.g. mkdir -p ./data).
DB_DSN=file:./data/app.db?_foreign_keys=on
DB_AUTO_MIGRATE=false

# Redis — used for cache.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Continuous profiling (only when observability docker stack / Pyroscope is enabled)
PYROSCOPE_SERVER_ADDRESS=http://localhost:4040
# With compose: Prometheus http://localhost:9090, Grafana http://localhost:3000, Pyroscope http://localhost:4040
